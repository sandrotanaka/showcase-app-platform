# Copy to secret.env (gitignored) and set real values, then run
# scripts/render-keycloak-realm.sh to render + apply the realm.
#
# These are the test-user passwords. The OIDC CLIENT SECRET is NOT here:
# Keycloak generates it (Form 2) and the operator publishes it as a Secret in
# the showcase-keycloak namespace; Developer Hub reads it from there.
#
# secret.env must never be committed. Only this .example lives in Git.

SHOWCASE_ADMIN_PASSWORD=replace-me
SHOWCASE_USER_PASSWORD=replace-me
