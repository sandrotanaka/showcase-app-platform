# Never commit real environment values or secrets.
# Only *.example files (keys, no values) belong in Git.
*.env
!*.env.example
!scripts/foundation-versions.env
*.secret.env
secret.env
config.env
.DS_Store

# Local tooling
.idea/
.vscode/
*.log

# Real environment fact sheet (sensitive identifiers: hosts, URLs, users, realm).
# Keep your real values here, OUT of Git. Copy from docs/ENVIRONMENT.example.md.
docs/ENVIRONMENT.local.md
*.local.md
*.local.env

# Argo CD repo-access credentials (PAT / SSH deploy key) — never commit
foundation/gitops/repo-secret.env
*deploy_key*
*.pem
sshPrivateKey
