# Pinned foundation operator versions (phase 1).
# Single source of truth: the prerequisite checker reads this, and the
# Subscription manifests will pin the same values. Confirmed against the cluster
# catalog (OpenShift 4.20). installPlanApproval will be Manual.
#
# To change a pin: update here, re-run scripts/check-prerequisites.sh to confirm
# the CSV exists in the catalog, then update the Subscription manifest.

# Red Hat OpenShift GitOps
GITOPS_PACKAGE=openshift-gitops-operator
GITOPS_CHANNEL=gitops-1.20
GITOPS_CSV=openshift-gitops-operator.v1.20.4

# Red Hat build of Keycloak (RHBK)
KEYCLOAK_PACKAGE=rhbk-operator
KEYCLOAK_CHANNEL=stable-v26.6
KEYCLOAK_CSV=rhbk-operator.v26.6.3-opr.1

# Red Hat Developer Hub (RHDH)
RHDH_PACKAGE=rhdh
RHDH_CHANNEL=fast-1.10
RHDH_CSV=rhdh-operator.v1.10.1

# Minimum OpenShift version for the platform
MIN_OCP_MINOR=14
